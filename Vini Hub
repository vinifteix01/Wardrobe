let modalType='at';

function openModal(id) {
  editingId=id;
  const s=id!=null?state.sessions.find(x=>x.id===id):null;
  document.getElementById('session-modal').classList.remove('hidden');
  document.getElementById('modal-title').textContent=s?'Editar sessão':'Nova sessão';
  document.getElementById('modal-save').textContent=s?'Salvar':'Criar sessão';
  document.getElementById('modal-error').classList.add('hidden');
  document.getElementById('future-callout').classList.add('hidden');

  modalType=s?.type||'at';
  document.getElementById('f-patient').value=s?.patient||'';
  document.getElementById('f-supervisor').value=s?.supervisor||'';
  document.getElementById('f-date').value=s?.date||todayStr();
  document.getElementById('f-time').value=s?.time||'09:00';
  document.getElementById('f-room').value=s?.room||'';

  updateModalType(modalType);
  updateFutureCallout();
}

function updateModalType(type) {
  modalType=type;
  document.querySelectorAll('.type-opt').forEach(b=>{
    b.classList.toggle('active', b.dataset.type===type);
  });
  document.getElementById('patient-req').textContent=type==='at'?'*':'';
  document.getElementById('sup-req').textContent=type==='esp'?'*':'';
  document.getElementById('room-field').style.display=type==='esp'?'none':'';
}

function updateFutureCallout() {
  const date=document.getElementById('f-date').value;
  const isFut=date>todayStr();
  document.getElementById('future-callout').classList.toggle('hidden',!isFut);
}

function closeModal() {
  document.getElementById('session-modal').classList.add('hidden');
  editingId=null;
}

function saveModal() {
  const patient=document.getElementById('f-patient').value.trim();
  const supervisor=document.getElementById('f-supervisor').value.trim();
  const date=document.getElementById('f-date').value;
  const time=document.getElementById('f-time').value;
  const room=modalType==='esp'?'':document.getElementById('f-room').value;

  const errEl=document.getElementById('modal-error');
  function showErr(msg){errEl.textContent=msg;errEl.classList.remove('hidden');return false;}

  if(modalType==='at'&&!patient) return showErr('Atendimento requer o nome do paciente.');
  if(modalType==='esp'&&!supervisor) return showErr('Espelho requer o nome do colega/supervisor.');
  if(!date) return showErr('Informe a data.');
  if(!time) return showErr('Informe o horário.');

  if(editingId!=null) {
    const s=state.sessions.find(x=>x.id===editingId);
    if(!s) return;
    if(s.type!==modalType) s.checks=emptyChecks(modalType);
    s.patient=patient; s.supervisor=supervisor;
    s.date=date; s.time=time; s.type=modalType; s.room=room;
    showToast('Sessão atualizada');
  } else {
    state.sessions.push({
      id:state.nextId++,
      patient,supervisor,date,time,type:modalType,dur:1,room,
      checks:emptyChecks(modalType),
    });
    showToast('Sessão criada');
  }
  save(state); closeModal(); render();
}

// ═══════════════════════════════════════════════════════════════════
// ROOM MODAL
// ═══════════════════════════════════════════════════════════════════
function openRoomModal(id) {
  quickRoomId=id;
  const s=state.sessions.find(x=>x.id===id);
  if(!s) return;
  document.getElementById('room-modal').classList.remove('hidden');
  document.getElementById('room-modal-sub').textContent=
    (s.patient||s.supervisor||'—')+' · '+fmtDate(s)+' '+s.time;
  const grid=document.getElementById('room-grid');
  grid.innerHTML=['1','2','3','4','5','6'].map(r=>
    `<button class="room-btn${s.room===r?' active':''}" data-room="${r}">Sala ${r}</button>`
  ).join('');
}

function closeRoomModal() {
  document.getElementById('room-modal').classList.add('hidden');
  quickRoomId=null;
}

// ═══════════════════════════════════════════════════════════════════
// EXPORT / IMPORT
// ═══════════════════════════════════════════════════════════════════
function exportCSV() {
  const rows=[['id','data','horario','paciente','supervisor','tipo','sala','duracao',
    'prontuario','pendencias','relatorio','anotacoes','pesquisa'].join(',')];
  state.sessions.forEach(s=>{
    const esc=v=>`"${String(v).replace(/"/g,'""')}"`;
    const b=v=>v===undefined?'':v?'1':'0';
    rows.push([s.id,esc(s.date),esc(s.time),esc(s.patient),esc(s.supervisor),
      s.type,esc(s.room),s.dur,
      b(s.checks.prontuario),b(s.checks.pendencias),b(s.checks.relatorio),
      b(s.checks.anotacoes),b(s.checks.pesquisa)].join(','));
  });
  download('sessoes.csv', rows.join('\n'), 'text/csv;charset=utf-8');
}

function exportJSON() {
  download('backup.json', JSON.stringify({sessions:state.sessions,nextId:state.nextId},null,2), 'application/json');
}

function download(name, content, mime) {
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([content],{type:mime}));
  a.download=name; a.click(); URL.revokeObjectURL(a.href);
}

function importJSON(raw) {
  try {
    const d=JSON.parse(raw);
    if(!d||!Array.isArray(d.sessions)) throw new Error();
    state.sessions=d.sessions;
    state.nextId=typeof d.nextId==='number'?d.nextId:d.sessions.length+1;
    save(state); render(); showToast('Importado com sucesso');
  } catch { showToast('Arquivo inválido','err'); }
}

// ═══════════════════════════════════════════════════════════════════
// EVENT BINDINGS (global)
// ═══════════════════════════════════════════════════════════════════
// Nav tabs
document.querySelectorAll('.nav-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    currentPage=btn.dataset.page;
    render();
  });
});

// Sidebar items
document.querySelector('.sidebar').addEventListener('click', e=>{
  const item=e.target.closest('.sb-item[data-sb]');
  if(!item) return;
  const filter=item.dataset.filter;
  currentPage='estagio';
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector('.nav-btn[data-page="estagio"]').classList.add('active');
  if(filter){ currentFilter=filter; }
  render();
});

// Sidebar export buttons
document.getElementById('btn-export-csv').addEventListener('click',exportCSV);
document.getElementById('btn-export-json').addEventListener('click',exportJSON);
document.getElementById('btn-reset').addEventListener('click',()=>{
  if(confirm('Resetar todos os dados para o seed inicial?')){
    state=buildSeed(); save(state); render(); showToast('Dados resetados','err');
  }
});
document.getElementById('btn-import').addEventListener('click',()=>{
  document.getElementById('file-input').click();
});
document.getElementById('file-input').addEventListener('change',e=>{
  const f=e.target.files?.[0]; if(!f) return;
  const r=new FileReader();
  r.onload=()=>importJSON(r.result);
  r.readAsText(f);
  e.target.value='';
});

// Session modal
document.getElementById('modal-close').addEventListener('click',closeModal);
document.getElementById('modal-cancel').addEventListener('click',closeModal);
document.getElementById('modal-save').addEventListener('click',saveModal);
document.getElementById('session-modal').addEventListener('click',e=>{
  if(e.target===document.getElementById('session-modal')) closeModal();
});
document.querySelectorAll('.type-opt').forEach(btn=>{
  btn.addEventListener('click',()=>updateModalType(btn.dataset.type));
});
document.getElementById('f-date').addEventListener('input',updateFutureCallout);

// Room modal
document.getElementById('room-modal-close').addEventListener('click',closeRoomModal);
document.getElementById('room-modal-cancel').addEventListener('click',closeRoomModal);
document.getElementById('room-modal').addEventListener('click',e=>{
  if(e.target===document.getElementById('room-modal')) closeRoomModal();
});
document.getElementById('room-grid').addEventListener('click',e=>{
  const btn=e.target.closest('.room-btn');
  if(!btn||quickRoomId==null) return;
  const s=state.sessions.find(x=>x.id===quickRoomId);
  if(s){ s.room=btn.dataset.room; save(state); render(); showToast('Sala '+btn.dataset.room+' registrada'); }
  closeRoomModal();
});

// Keyboard
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){closeModal();closeRoomModal();}
});

// ── INITIAL RENDER ───────────────────────────────────────────────
render();
</script>
</body>
</html>
