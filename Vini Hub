<script>
// ═══════════════════════════════════════════════════════════════════
// DATA & STORAGE
// ═══════════════════════════════════════════════════════════════════
const KEY = 'hub_pessoal_v2';
const KEY_V1 = 'hub_pessoal_v1';
const TARGET = 40;

function load() {
  try {
    const raw = localStorage.getItem(KEY);
    if (raw) { const d = JSON.parse(raw); if (d && Array.isArray(d.sessions)) return d; }
  } catch {}
  // Try v1 migration
  try {
    const raw = localStorage.getItem(KEY_V1);
    if (raw) {
      const d = JSON.parse(raw);
      if (d && Array.isArray(d.sessions)) {
        const sessions = d.sessions.map(s => ({
          ...s,
          patient: s.patient ?? (s.type === 'at' ? (s.name || '') : ''),
          supervisor: s.supervisor ?? (s.type === 'esp' ? (s.name || '') : ''),
        }));
        return { sessions, nextId: d.nextId };
      }
    }
  } catch {}
  return null;
}

function save(state) {
  try { localStorage.setItem(KEY, JSON.stringify({ sessions: state.sessions, nextId: state.nextId })); } catch {}
}

// ── SEED ────────────────────────────────────────────────────────────
function makeDate(daysAgo) {
  const d = new Date(); d.setHours(0,0,0,0); d.setDate(d.getDate() - daysAgo);
  return d.toISOString().slice(0,10);
}
function buildSeed() {
