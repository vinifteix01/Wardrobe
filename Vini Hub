      <div class="ph-sub">Em construção — módulo disponível em breve.</div>
    </div>`;
}

function renderEstagio() {
  const done=doneHours(), planned=plannedHours(), gap=Math.max(0,TARGET-done-planned);
  const donePct=Math.min(100,(done/TARGET)*100);
  const planPct=Math.min(100-donePct,(planned/TARGET)*100);
  const list=getFiltered();

  document.getElementById('main-content').innerHTML=`
    <div class="page-header">
      <div>
        <div class="page-title">Estágio Clínico</div>
        <div class="page-sub">rastreamento de 40h obrigatórias no semestre</div>
      </div>
      <div class="header-actions">
        <button class="btn btn-primary" id="btn-new">+ Nova sessão</button>
      </div>
    </div>

    <div class="scroll-area">
      <!-- STATS -->
      <div class="stat-row">
        <div class="stat-card lime">
          <div class="stat-label"><div class="stat-dot"></div>Horas cumpridas</div>
