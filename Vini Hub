    const roomBtn=e.target.closest('.room-missing');
    const row=e.target.closest('tr[data-id]');
    if(editBtn){ openModal(+editBtn.dataset.id); return; }
    if(delBtn){
      const s=state.sessions.find(x=>x.id===+delBtn.dataset.id);
      const label=s?.patient||s?.supervisor||'esta sessão';
      if(confirm(`Excluir ${label}?`)){
        state.sessions=state.sessions.filter(x=>x.id!==+delBtn.dataset.id);
        save(state); render(); showToast('Sessão excluída','err');
      }
      return;
    }
    if(roomBtn){ openRoomModal(+roomBtn.dataset.id); return; }
    if(row&&!e.target.closest('button')&&!e.target.closest('input')){
      openModal(+row.dataset.id);
    }
  });
}

