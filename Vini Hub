  document.getElementById('btn-new')?.addEventListener('click', ()=>openModal(null));
  document.getElementById('btn-new2')?.addEventListener('click', ()=>openModal(null));

  document.getElementById('tbl-body')?.addEventListener('change', e=>{
    if(!e.target.matches('.chk')) return;
    const id=+e.target.dataset.id, key=e.target.dataset.k;
    const s=state.sessions.find(x=>x.id===id);
    if(!s||isUpcoming(s)) { e.target.checked=!e.target.checked; return; }
    s.checks[key]=e.target.checked;
    save(state); updateSidebar();
    showToast(e.target.checked ? '✓ Tarefa marcada' : 'Tarefa desmarcada');
  });

  document.getElementById('tbl-body')?.addEventListener('click', e=>{
    const editBtn=e.target.closest('[data-action="edit"]');
