        </div>
        <div class="stat-card">
          <div class="stat-label"><div class="stat-dot" style="background:var(--purple)"></div>Agendadas</div>
          <div class="stat-num" style="font-size:30px;color:var(--purple)">${planned.toFixed(1)}<span style="font-size:15px;color:var(--muted);font-weight:400;margin-left:3px;">h</span></div>
          <div class="stat-sub">total: <span style="color:var(--purple);font-weight:700">${(done+planned).toFixed(1)}h</span> planejadas</div>
        </div>
        <div class="stat-card">
          <div class="stat-label"><div class="stat-dot" style="background:var(--accent)"></div>Atendimentos</div>
          <div class="stat-num" style="font-size:30px">${state.sessions.filter(s=>s.type==='at'&&!isUpcoming(s)).length}<span style="font-size:15px;color:var(--muted);font-weight:400;margin-left:4px;">sessões</span></div>
          <div class="stat-sub">${state.sessions.filter(s=>s.type==='esp'&&!isUpcoming(s)).length} espelhos realizados</div>
        </div>
        <div class="stat-card">
          <div class="stat-label"><div class="stat-dot" style="background:var(--warn)"></div>Conclusão</div>
          <div class="stat-num" style="font-size:30px;color:${completionRate()>=70?'var(--accent)':'var(--warn)'}">${completionRate()}<span style="font-size:15px;font-weight:400;margin-left:1px;">%</span></div>
          <div class="stat-sub">checklists completos</div>
        </div>
      </div>

      <!-- PROGRESS BAR -->
      <div class="progress-card">
        <div class="prog-header">
          <div class="prog-title">Progresso rumo às 40h</div>
          <div class="prog-detail">
            <span style="color:var(--accent);font-weight:700">${done.toFixed(1)}h</span> cumpridas
            + <span style="color:var(--purple);font-weight:600">${planned.toFixed(1)}h</span> agendadas
            = <span style="color:var(--text);font-weight:600">${(done+planned).toFixed(1)}h</span>
          </div>
        </div>
        <div class="prog-bar-wrap">
          <div class="prog-bar-done" style="width:${donePct}%"></div>
          <div class="prog-bar-plan" style="width:${planPct}%"></div>
        </div>
        <div class="prog-legend">
          <div class="legend-item"><div class="legend-dot" style="background:var(--accent)"></div>Cumpridas · ${done.toFixed(1)}h</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--purple)"></div>Agendadas · ${planned.toFixed(1)}h</div>
          <div class="prog-gap ${gap===0?'ok':''}">${gap>0?'Faltam '+gap.toFixed(1)+'h para planejar':'Meta atingida!'}</div>
        </div>
      </div>

      <!-- SESSIONS TABLE -->
      <div class="sessions-card">
        <div class="sessions-header">
          <div class="filter-chips" id="filter-chips">
            ${[
              {k:'all',l:'Todas'},
              {k:'at',l:'Atendimentos'},
              {k:'esp',l:'Espelhos'},
              {k:'upcoming',l:'Agendadas'},
              {k:'pending',l:'Pendências'},
              {k:'overdue',l:'Atrasadas'},
            ].map(f=>`<button class="chip${currentFilter===f.k?' active':''}" data-f="${f.k}">${f.l}</button>`).join('')}
          </div>
          <button class="add-fab" id="btn-new2">+</button>
