  const espF={anotacoes:true,pesquisa:true}, espE={anotacoes:false,pesquisa:false};
  const s=(id,patient,supervisor,off,time,type,room,checks)=>
    ({id,patient,supervisor,date:makeDate(off),time,type,dur:1,room,checks});
  return { nextId:28, sessions:[
    s(1,'Sofia Marques',HEL,18,'09:00','at','2',full),
    s(2,'Carlos Ribeiro',HEL,18,'10:00','at','3',full),
    s(3,'',PAU,17,'14:00','esp','',espF),
    s(4,'Beatriz Lopes',HEL,15,'09:30','at','1',full),
    s(5,'',MAR,15,'11:00','esp','',espF),
    s(6,'Sofia Marques',HEL,11,'09:00','at','2',full),
    s(7,'Carlos Ribeiro',HEL,11,'10:00','at','3',full),
    s(8,'Pedro Almeida',HEL,10,'10:00','at','4',full),
    s(9,'Beatriz Lopes',HEL,8,'09:30','at','1',full),
    s(10,'',PAU,9,'14:00','esp','',espF),
    s(11,'',MAR,8,'11:00','esp','',{anotacoes:true,pesquisa:false}),
    s(12,'Sofia Marques',HEL,5,'09:00','at','2',full),
    s(13,'Carlos Ribeiro',HEL,5,'10:00','at','3',full),
    s(14,'Pedro Almeida',HEL,4,'10:00','at','4',{prontuario:true,pendencias:true,relatorio:false,pesquisa:false}),
    s(15,'Marina Cardoso',HEL,4,'11:00','at','5',empty),
    s(16,'',PAU,3,'14:00','esp','',espE),
    s(17,'',MAR,3,'15:00','esp','',espF),
    s(18,'Sofia Marques',HEL,2,'09:00','at','2',full),
    s(19,'Carlos Ribeiro',HEL,1,'10:00','at','',{prontuario:true,pendencias:false,relatorio:false,pesquisa:false}),
    s(20,'Pedro Almeida',HEL,0,'10:00','at','4',empty),
    s(21,'',PAU,0,'14:00','esp','',espE),
    // future (negative = future days from today)
    s(22,'Sofia Marques',HEL,-1,'09:00','at','2',empty),
    s(23,'Carlos Ribeiro',HEL,-2,'10:00','at','3',empty),
    s(24,'',PAU,-3,'14:00','esp','',espE),
    s(25,'Beatriz Lopes',HEL,-7,'09:30','at','1',empty),
    s(26,'Pedro Almeida',HEL,-8,'10:00','at','4',empty),
    s(27,'',MAR,-9,'11:00','esp','',espE),
  ]};
}

// ═══════════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════════
let state = load() || buildSeed();
if (!load()) save(state);

let currentPage = 'estagio';
let currentFilter = 'all';
let editingId = null;
let quickRoomId = null;

// ═══════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════
const MONTHS = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
const WDAYS  = ['dom','seg','ter','qua','qui','sex','sáb'];
const AT_KEYS  = ['prontuario','pendencias','relatorio','pesquisa'];
const ESP_KEYS = ['anotacoes','pesquisa'];
const CHECK_LABELS = {prontuario:'Prontuário',pendencias:'Pendências',relatorio:'Relatório',anotacoes:'Anotações',pesquisa:'Pesquisa'};

function today() {
  const d = new Date(); d.setHours(0,0,0,0); return d;
}
function parseDateStr(s) {
  const [y,m,d] = s.split('-').map(Number); return new Date(y,m-1,d);
}
function todayStr() {
  return today().toISOString().slice(0,10);
}
function daysAgo(s) {
  return Math.floor((today() - parseDateStr(s.date)) / 86400000);
}
function isUpcoming(s) { return daysAgo(s) < 0; }
function keysFor(s)    { return s.type === 'at' ? AT_KEYS : ESP_KEYS; }
function completion(s) {
  const k = keysFor(s); const done = k.filter(x => s.checks[x]).length;
  return { done, total: k.length };
}
function isComplete(s) { const c = completion(s); return c.done === c.total; }
function isMissing(s)  { return s.type === 'at' && !s.room && !isUpcoming(s); }
function isOverdue(s)  { return !isUpcoming(s) && !isComplete(s) && daysAgo(s) > 2; }
function phaseOf(s) {
  if (isUpcoming(s)) return 'upcoming';
  if (daysAgo(s) === 0) return 'today';
  return 'past';
}
function fmtDate(s) {
  const d = parseDateStr(s.date);
  return WDAYS[d.getDay()] + ' ' + d.getDate() + ' ' + MONTHS[d.getMonth()];
}
function statusOf(s) {
  if (isUpcoming(s)) return {cls:'upcoming',label:'Agendada'};
  if (isComplete(s)) return {cls:'complete',label:'Completo'};
  if (isOverdue(s))  return {cls:'overdue', label:'Atrasado'};
  const c = completion(s);
  if (c.done === 0)  return {cls:'empty',   label:'Vazio'};
  return {cls:'partial', label:`Parcial ${c.done}/${c.total}`};
}
function emptyChecks(type) {
  return type === 'at'
    ? {prontuario:false,pendencias:false,relatorio:false,pesquisa:false}
    : {anotacoes:false,pesquisa:false};
}
function doneHours()    { return state.sessions.filter(s=>!isUpcoming(s)).reduce((a,s)=>a+s.dur,0); }
function plannedHours() { return state.sessions.filter(isUpcoming).reduce((a,s)=>a+s.dur,0); }
function completionRate() {
  const past = state.sessions.filter(s=>!isUpcoming(s));
  if (!past.length) return 0;
  return Math.round(past.filter(isComplete).length / past.length * 100);
}
function getFiltered() {
  let list = state.sessions.slice();
  if      (currentFilter==='at')       list=list.filter(s=>s.type==='at');
  else if (currentFilter==='esp')      list=list.filter(s=>s.type==='esp');
  else if (currentFilter==='upcoming') list=list.filter(isUpcoming);
  else if (currentFilter==='pending')  list=list.filter(s=>!isUpcoming(s)&&!isComplete(s));
  else if (currentFilter==='overdue')  list=list.filter(isOverdue);
  else if (currentFilter==='missing')  list=list.filter(isMissing);
  list.sort((a,b)=>{
    const au=isUpcoming(a),bu=isUpcoming(b);
    if(au&&!bu)return -1; if(!au&&bu)return 1;
    const da=parseDateStr(a.date),db=parseDateStr(b.date);
    if(au&&bu) return da-db||a.time.localeCompare(b.time);
    return db-da||a.time.localeCompare(b.time);
  });
  return list;
}

// ═══════════════════════════════════════════════════════════════════
// TOAST
// ═══════════════════════════════════════════════════════════════════
let toastTimer;
function showToast(msg, type='ok') {
  const el=document.getElementById('toast');
  const dot=document.getElementById('toast-dot');
  document.getElementById('toast-msg').textContent=msg;
  dot.className='toast-dot'+(type==='err'?' red':'');
  el.classList.remove('hidden');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.add('hidden'),2800);
}

// ═══════════════════════════════════════════════════════════════════
// SIDEBAR COUNTERS
// ═══════════════════════════════════════════════════════════════════
function updateSidebar() {
  const rooms   = state.sessions.filter(isMissing).length;
  const overdue = state.sessions.filter(isOverdue).length;
  const done    = doneHours(), planned = plannedHours();
  const gap     = Math.max(0, TARGET - done - planned);
  document.getElementById('sb-room-count').textContent = rooms;
  document.getElementById('sb-overdue-count').textContent = overdue;
  document.getElementById('sb-gap-val').textContent = gap > 0 ? gap.toFixed(1)+'h' : '✓';
  document.getElementById('sb-room-alert').style.display = rooms ? '' : 'none';
  document.getElementById('sb-overdue-alert').style.display = overdue ? '' : 'none';
}

// ═══════════════════════════════════════════════════════════════════
// RENDER PAGES
// ═══════════════════════════════════════════════════════════════════
function render() {
  updateSidebar();
  if (currentPage !== 'estagio') { renderPlaceholder(); return; }
  renderEstagio();
}

function renderPlaceholder() {
  const labels={projetos:'Projetos de Vida',financas:'Finanças Pessoais',investimentos:'Investimentos'};
  const icons ={projetos:'🗂️',financas:'💳',investimentos:'📈'};
  document.getElementById('main-content').innerHTML=`
    <div class="placeholder-page">
      <div class="ph-icon">${icons[currentPage]||'🔧'}</div>
